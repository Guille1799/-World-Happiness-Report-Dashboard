# Copy to `.env` on your machine only. Never commit `.env`.

# Optional: Telegram (if you wire a bot to this project)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789

# Optional: absolute path to a WHR Excel (legacy or Figure 2.1)
# WHR_DATA_PATH=C:/path/to/workbook.xlsx

# Set to 1 to disable automatic download of the official WHR Figure 2.1 xlsx
# WHR_NO_AUTO_DOWNLOAD=0

# Set to 1/true to hide the yellow "Demo mode" banner (use on Streamlit Cloud Secrets too)
# WHR_HIDE_DEMO_BANNER=0

# Local population CSV (World Bank–style) when offline
# WHR_POPULATION_CSV=C:/path/to/population.csv
