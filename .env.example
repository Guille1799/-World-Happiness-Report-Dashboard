# Copia este archivo como `.env` solo en tu máquina local.
# NO subas `.env` a GitHub.

# Opcional: Telegram (si enlazas un bot a este proyecto)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789

# Opcional: ruta absoluta a un Excel WHR (legacy o Figure 2.1)
# WHR_DATA_PATH=C:/ruta/a/tu/archivo.xlsx

# Evitar descarga automática del Excel oficial (1 = sí desactivar)
# WHR_NO_AUTO_DOWNLOAD=0

# Población local si no hay red (CSV estilo World Bank / datasets)
# WHR_POPULATION_CSV=C:/ruta/a/population.csv
